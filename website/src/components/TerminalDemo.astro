<div class="bg-terminal-bg text-terminal-text rounded-lg font-mono text-[0.85rem] max-md:text-[0.75rem] overflow-hidden">
  <div class="px-5 py-4 min-h-[13rem] max-md:min-h-[14rem]">
    <div id="terminal-lines"></div>
  </div>
</div>

<style is:global>
  #terminal-cursor {
    display: inline-block;
    width: 0.5em;
    height: 1.15em;
    background: var(--color-terminal-text);
    vertical-align: text-bottom;
    position: relative;
    top: -2px;
    margin-left: 1px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  .t-line {
    white-space: pre;
    line-height: 1.7;
    min-height: 1.7em;
  }
  .t-bold { font-weight: 700; }
  .t-dim { color: var(--color-terminal-muted); }
  .t-green { color: #4ade80; }
  .t-prompt { color: var(--color-terminal-muted); user-select: none; }
</style>

<script>
  const scenes = [
    [
      {
        command: "caldir pull",
        lines: [
          '<span class="t-green">Pulled 4 events</span> <span class="t-dim">from Google Calendar</span>',
          '<span class="t-green">Pulled 1 event</span> <span class="t-dim">from iCloud</span>',
        ],
      },
      {
        command: "ls ~/caldir/work/",
        lines: [
          "2026-03-02T0900__standup.ics",
          "2026-03-02T1400__sprint-planning.ics",
          "2026-03-03T1000__one-on-one.ics",
          "2026-03-04T1100__design-review.ics",
        ],
      },
    ],
    [
      {
        command: 'caldir new "Lunch with Sara" --start \'fri 12:00\'',
        lines: ['<span class="t-green">  Created: Lunch with Sara</span>'],
      },
      {
        command: "caldir push",
        lines: [
          "📅 google-calendar",
          '   <span class="t-green">+ Lunch with Sara</span> <span class="t-dim">Fri Mar 6, 12:00</span>',
          "\u00a0",
          "Pushed: 1 created, 0 updated, 0 deleted",
        ],
      },
    ],
    [
      {
        command: "grep -r 'sprint' ~/caldir/",
        lines: [
          "work/2026-03-01T1400__sprint-planning.ics:SUMMARY:Sprint planning",
          "work/2026-03-08T1400__sprint-review.ics:SUMMARY:Sprint review",
        ],
      },
    ],
  ];

  const CHAR_MS = 25;
  const PAUSE_AFTER_CMD = 300;
  const LINE_DELAY = 60;
  const READ_PAUSE = 3000;

  const container = document.getElementById("terminal-lines")!;

  const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

  function addLine(html = "") {
    const el = document.createElement("div");
    el.className = "t-line";
    if (html) el.innerHTML = html;
    container.appendChild(el);
    return el;
  }

  function promptLine() {
    const line = addLine();
    line.innerHTML =
      '<span class="t-prompt">$ </span><span id="terminal-cursor"></span>';
    return line;
  }

  async function typeCmd(cmd: string) {
    // Remove the idle prompt cursor before typing
    const idleCursor = container.querySelector("#terminal-cursor");
    if (idleCursor) idleCursor.parentElement!.remove();

    const line = addLine();
    line.innerHTML = '<span class="t-prompt">$ </span>';
    const text = document.createElement("span");
    const cursor = document.createElement("span");
    cursor.id = "terminal-cursor";
    line.append(text, cursor);
    for (const ch of cmd) {
      text.textContent += ch;
      await sleep(CHAR_MS);
    }
    cursor.remove();
  }

  async function showLines(lines: string[]) {
    for (const html of lines) {
      addLine(html);
      await sleep(LINE_DELAY);
    }
  }

  function clear() {
    container.innerHTML = "";
  }

  (async () => {
    // Show idle prompt on load
    promptLine();
    await sleep(1000);

    while (true) {
      for (const scene of scenes) {
        clear();
        for (const step of scene) {
          promptLine();
          await sleep(400);
          await typeCmd(step.command);
          await sleep(PAUSE_AFTER_CMD);
          await showLines(step.lines);
        }
        promptLine();
        await sleep(READ_PAUSE);
      }
    }
  })();
</script>
