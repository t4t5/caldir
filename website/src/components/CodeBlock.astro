---
interface Props {
  code: string;
}

import CopyButton from "./CopyButton.astro";

const { code } = Astro.props;
---

<div data-code-block class="bg-terminal-bg text-terminal-text px-5 py-4 rounded-lg font-mono text-[0.95rem] max-md:text-[0.8rem] flex items-center overflow-visible">
  <span class="text-terminal-muted select-none mr-2">$</span>
  <code data-code class="flex-1">{code}</code>
  <CopyButton />
</div>

<script>
  document.querySelectorAll('[data-code-block]').forEach((block) => {
    const code = block.querySelector('[data-code]') as HTMLElement;
    const button = block.querySelector('[data-copy-button]') as HTMLButtonElement;
    const tooltip = block.querySelector('[data-tooltip]') as HTMLElement;

    let timeout: ReturnType<typeof setTimeout>;

    button.addEventListener('click', () => {
      navigator.clipboard.writeText(code.innerText);
      tooltip.dataset.visible = 'true';
      button.title = 'Copied!';
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        tooltip.dataset.visible = 'false';
        button.title = 'Copy to clipboard';
      }, 1500);
    });
  });
</script>
