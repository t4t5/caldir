---
import fs from "node:fs";
import path from "node:path";
import { docsLinks } from "../data/docs-links";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const cargoTomlPath = path.resolve("../caldir-cli/Cargo.toml");
const cargoToml = fs.readFileSync(cargoTomlPath, "utf8");
const version = cargoToml.match(/^version\s*=\s*"([^"]+)"/m)?.[1] ?? "";
---

<aside class="hidden md:flex flex-col gap-8 w-[136px] shrink-0 sticky top-20 self-start">
  <a href="/" aria-label="caldir home" class="block size-6">
    <img src="/logo.svg" alt="caldir" class="block size-6" />
  </a>

  <nav>
    <ul class="flex flex-col gap-3 text-[15px] list-none p-0">
      {docsLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block no-underline",
              currentSlug === link.slug ? "text-text-body" : "text-text-muted hover:text-text-body",
            ]}
          >
            {link.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="flex items-center gap-0">
    <span class="font-display text-[12px] text-text-muted w-[50px]">v{version}</span>
    <a
      href="https://github.com/t4t5/caldir"
      aria-label="GitHub repository"
      class="block size-4 text-text-muted hover:text-text-body"
    >
      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="block size-4">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
    </a>
  </div>
</aside>
