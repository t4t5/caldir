---
import fs from "node:fs";
import path from "node:path";
import DocsNavLinks from "./DocsNavLinks.astro";
import GithubIcon from "../icons/github.astro";
import Logo from "../icons/logo.astro";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const cargoTomlPath = path.resolve("../caldir-cli/Cargo.toml");
const cargoToml = fs.readFileSync(cargoTomlPath, "utf8");
const version = cargoToml.match(/^version\s*=\s*"([^"]+)"/m)?.[1] ?? "";
---

<aside class="hidden md:flex flex-col gap-8 w-[136px] shrink-0 sticky top-20 self-start">
  <a href="/" aria-label="caldir home" class="block size-6 text-text-heading">
    <Logo class="block size-6" />
  </a>

  <nav class="py-4">
    <DocsNavLinks currentSlug={currentSlug} />
  </nav>

  <div class="flex items-center gap-0">
    <a
      href="https://crates.io/crates/caldir-cli"
      target="_blank"
      class="font-display text-[12px] text-text-muted hover:text-text-body no-underline w-[50px]"
    >
      v{version}
    </a>
    <a
      href="https://github.com/t4t5/caldir"
      target="_blank"
      aria-label="GitHub repository"
      class="block size-4 text-text-muted hover:text-text-body"
    >
      <GithubIcon class="block size-4" />
    </a>
  </div>
</aside>
