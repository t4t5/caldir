---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Your calendar as a directory" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://caldir.org/og.png">
  <meta property="og:url" content="https://caldir.org">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/favicon-black.ico">
  <link rel="icon" href="/favicon-black.ico" media="(prefers-color-scheme: light)">
  <link rel="icon" href="/favicon-white.ico" media="(prefers-color-scheme: dark)">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&family=Anonymous+Pro&display=swap">
  <script defer data-domain="caldir.org" src="https://analytics.t4t5.xyz/js/script.js"></script>
</head>
<body class="bg-background text-text-body font-sans">
  <slot />
</body>
</html>

<style>
  @import "../styles/global.css";
</style>
