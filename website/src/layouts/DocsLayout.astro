---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import Footer from "../components/Footer.astro";
import { docsLinks } from "../data/docs-links";

interface Props {
  title: string;
  currentSlug?: string;
}

const { title, currentSlug } = Astro.props;
const currentIndex = docsLinks.findIndex((l) => l.slug === currentSlug);
const prevLink = currentIndex > 0 ? docsLinks[currentIndex - 1] : null;
const nextLink = currentIndex >= 0 && currentIndex < docsLinks.length - 1 ? docsLinks[currentIndex + 1] : null;
---

<BaseLayout title={title === "caldir" ? "caldir" : `${title} — caldir docs`}>
  <!-- Mobile -->
  <div class="md:hidden flex flex-col gap-[38px] p-7 min-h-screen" data-mobile-root>
    <header class="flex items-center justify-between w-full">
      <a href="/" aria-label="caldir home" class="block size-6">
        <img src="/logo.svg" alt="caldir" class="block size-6" />
      </a>
      <button
        type="button"
        aria-label="Toggle navigation"
        aria-expanded="false"
        class="size-6 relative text-logo cursor-pointer"
        data-mobile-toggle
      >
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 block w-[15.43px] h-[2.57px] rounded-[3.86px] bg-current transition-transform -translate-y-[3.71px] group-open:translate-y-0 group-open:rotate-45" data-mobile-bar-top></span>
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 block w-[15.43px] h-[2.57px] rounded-[3.86px] bg-current transition-transform translate-y-[2.71px] group-open:translate-y-0 group-open:-rotate-45" data-mobile-bar-bottom></span>
      </button>
    </header>

    <nav class="hidden w-full" data-mobile-nav>
      <ul class="flex flex-col gap-3 text-[15px]">
        {docsLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block",
                currentSlug === link.slug ? "text-text-body" : "text-text-muted",
              ]}
            >
              {link.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <main class="flex flex-col gap-[40px] w-full">
      <article class="caldir-prose flex flex-col gap-[24px] w-full text-[14px]">
        <slot />
      </article>

      {(prevLink || nextLink) && (
        <nav class="flex justify-between w-full">
          {prevLink ? (
            <a href={prevLink.href} class="text-[15px] text-text-muted hover:text-text-body flex items-center gap-1.5">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" class="size-[18px]" aria-hidden="true"><path d="M11.25 4.5 6.75 9l4.5 4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {prevLink.title}
            </a>
          ) : <span />}
          {nextLink && (
            <a href={nextLink.href} class="text-[15px] font-medium text-text-link ml-auto flex items-center gap-1.5">
              {nextLink.title}
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" class="size-[18px]" aria-hidden="true"><path d="M6.75 4.5 11.25 9l-4.5 4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          )}
        </nav>
      )}

      <Footer />
    </main>
  </div>

  <!-- Desktop -->
  <div class="hidden md:flex justify-center items-start py-20 px-8">
    <div class="flex gap-[111px] items-start">
      <DocsSidebar currentSlug={currentSlug} />

      <main class="flex flex-col gap-[40px] w-[560px]">
        <article class="caldir-prose flex flex-col gap-[24px] w-full text-[15px]">
          <slot />
        </article>

        {(prevLink || nextLink) && (
          <nav class="flex justify-between w-full">
            {prevLink ? (
              <a href={prevLink.href} class="no-underline text-[15px] text-text-muted hover:underline flex items-center gap-1.5">
                <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" class="size-[18px]" aria-hidden="true"><path d="M11.25 4.5 6.75 9l4.5 4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {prevLink.title}
              </a>
            ) : <span />}
            {nextLink && (
              <a href={nextLink.href} class="no-underline hover:underline text-[15px] font-medium text-text-link ml-auto flex items-center gap-1.5">
                {nextLink.title}
                <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" class="size-[18px]" aria-hidden="true"><path d="M6.75 4.5 11.25 9l-4.5 4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            )}
          </nav>
        )}

        <Footer />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .caldir-prose :global(h1),
  .caldir-prose :global(h2),
  .caldir-prose :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.2;
    color: var(--color-text-heading);
    margin: 0;
  }

  .caldir-prose :global(p) {
    color: var(--color-text-body);
    line-height: 1.5;
    margin: 0;
  }

  .caldir-prose :global(a) {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .caldir-prose :global(a:hover) {
    text-decoration: underline;
  }

  .caldir-prose :global(ul),
  .caldir-prose :global(ol) {
    color: var(--color-text-body);
    line-height: 1.5;
    margin: 0;
    padding-left: 1.5em;
  }

  .caldir-prose :global(li) {
    margin: 0.25em 0;
  }

  .caldir-prose :global(code) {
    font-family: var(--font-mono);
    background: var(--color-inline-code);
    padding: 0 6px;
  }

  .caldir-prose :global(pre) {
    border: 1px solid var(--color-codeblock-border);
    border-radius: 6px;
    padding: 18px;
    margin: 0;
    overflow-x: auto;
    background: transparent;
  }

  .caldir-prose :global(pre code) {
    background: transparent;
    padding: 0;
    line-height: 1.4;
    color: var(--color-text-code);
  }

  /* Desktop code sizes */
  @media (min-width: 880px) {
    .caldir-prose :global(code) { font-size: 14px; }
  }

  /* Mobile code sizes */
  @media (max-width: 879px) {
    .caldir-prose :global(code) { font-size: 12px; }
  }

  .caldir-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-separator);
    margin: 20px 0;
  }

  .caldir-prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-body);
  }
</style>

<script>
  const root = document.querySelector("[data-mobile-root]") as HTMLElement | null;
  const toggle = document.querySelector("[data-mobile-toggle]") as HTMLButtonElement | null;
  const nav = document.querySelector("[data-mobile-nav]") as HTMLElement | null;
  const barTop = document.querySelector("[data-mobile-bar-top]") as HTMLElement | null;
  const barBottom = document.querySelector("[data-mobile-bar-bottom]") as HTMLElement | null;

  if (root && toggle && nav && barTop && barBottom) {
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(isOpen));
      if (isOpen) {
        barTop.style.transform = "translate(-50%, 0) rotate(45deg)";
        barBottom.style.transform = "translate(-50%, 0) rotate(-45deg)";
      } else {
        barTop.style.transform = "";
        barBottom.style.transform = "";
      }
    });
  }
</script>
