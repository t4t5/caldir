---
import Meta from "../components/Meta.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import DocsNavLinks from "../components/DocsNavLinks.astro";
import DocsPrevNextNav from "../components/DocsPrevNextNav.astro";
import Footer from "../components/Footer.astro";
import HamburgerToggle from "../components/HamburgerToggle.astro";
import { docsLinks } from "../data/docs-links";
import Logo from "../icons/logo.astro";

interface Props {
  title: string;
  currentSlug?: string;
}

const { title, currentSlug } = Astro.props;
const pageTitle = title === "caldir" ? "Caldir - your calendar as a directory" : `Caldir • ${title}`;
const currentIndex = docsLinks.findIndex((l) => l.slug === currentSlug);
const prevLink = currentIndex > 0 ? docsLinks[currentIndex - 1] : null;
const nextLink = currentIndex >= 0 && currentIndex < docsLinks.length - 1 ? docsLinks[currentIndex + 1] : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <Meta title={pageTitle} />
</head>
<body class="bg-background text-text-body font-sans">
  <div class="flex flex-col gap-[38px] p-7 min-h-screen md:flex-row md:justify-center md:items-start md:gap-[111px] md:p-0 md:py-20 md:px-8">
    <header class="md:hidden flex items-center justify-between w-full">
      <a href="/" aria-label="caldir home" class="block size-6 text-text-heading">
        <Logo class="block size-6" />
      </a>
      <HamburgerToggle data-mobile-toggle />
    </header>

    <nav class="md:hidden hidden w-full" data-mobile-nav>
      <DocsNavLinks currentSlug={currentSlug} />
    </nav>

    <DocsSidebar currentSlug={currentSlug} />

    <main class="flex flex-col gap-[40px] w-full md:w-[560px]">
      <article class="caldir-prose flex flex-col gap-[24px] w-full text-[14px] md:text-[15px]">
        <slot />
      </article>

      <DocsPrevNextNav prevLink={prevLink} nextLink={nextLink} />

      <Footer />
    </main>
  </div>
</body>
</html>

<style>
  @import "../styles/global.css";

  .caldir-prose :global(h1),
  .caldir-prose :global(h2),
  .caldir-prose :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-text-heading);
    margin: 0;
  }

  .caldir-prose :global(h1) {
    font-size: 22px;
  }

  .caldir-prose :global(h2) {
    font-size: 20px;
  }

  .caldir-prose :global(h3) {
    font-size: 15px;
  }

  .caldir-prose :global(p) {
    color: var(--color-text-body);
    line-height: 1.5;
    margin: 0;
  }

  .caldir-prose :global(a) {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .caldir-prose :global(a:hover) {
    text-decoration: underline;
  }

  .caldir-prose :global(ul),
  .caldir-prose :global(ol) {
    color: var(--color-text-body);
    line-height: 1.5;
    margin: 0;
    padding-left: 1.5em;
  }

  .caldir-prose :global(li) {
    margin: 0.25em 0;
  }

  .caldir-prose :global(code) {
    font-family: var(--font-mono);
    background: var(--color-inline-code);
    padding: 0 6px;
  }

  .caldir-prose :global(pre) {
    border: 1px solid var(--color-codeblock-border);
    border-radius: 6px;
    padding: 18px;
    margin: 0;
    background: transparent;
  }

  .caldir-prose :global(pre code) {
    background: transparent;
    padding: 0;
    line-height: 1.4;
    color: var(--color-text-code);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .caldir-prose :global(table) {
    font-size: 13px;
    text-align: left;
  }

  /* Desktop code sizes */
  @media (min-width: 880px) {
    .caldir-prose :global(code) { font-size: 14px; }
  }

  /* Mobile code sizes */
  @media (max-width: 879px) {
    .caldir-prose :global(code) { font-size: 12px; }
  }

  .caldir-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-separator);
    margin: 20px 0;
  }

  .caldir-prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-body);
  }

  .caldir-prose :global(summary) {
    cursor: pointer;
    margin-bottom: 8px;
  }

  .caldir-prose :global(summary:hover) {
    opacity: 0.6;
  }
</style>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]") as HTMLButtonElement | null;
  const nav = document.querySelector("[data-mobile-nav]") as HTMLElement | null;

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("data-open", String(isOpen));
    });
  }
</script>
