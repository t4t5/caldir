---
import Layout from "../layouts/Layout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("docs", "what-is-caldir");
if (!entry) throw new Error("Missing docs collection entry: what-is-caldir");
const { Content } = await render(entry);
---

<Layout title="caldir" currentSlug="what-is-caldir">
  <Content />
</Layout>
