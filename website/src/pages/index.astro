---
import DocsLayout from "../layouts/DocsLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("docs", "what-is-caldir");
if (!entry) throw new Error("Missing docs collection entry: what-is-caldir");
const { Content } = await render(entry);
---

<DocsLayout title="caldir" currentSlug="what-is-caldir">
  <Content />
</DocsLayout>
